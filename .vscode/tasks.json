{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-main-c",
      "type": "shell",
      "command": "C:/mingw64/bin/gcc.exe",
      "args": [
        "-g",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}.exe"
      ],
      "problemMatcher": ["$gcc"],
      "group": { "kind": "build", "isDefault": true }
    }
  ]
}